# ── 数据库 ──────────────────────────────────────────────────────
# PostgreSQL 连接字符串（必填）
DATABASE_URL=postgresql://user:password@localhost:5432/emotion_sphere

# ── 微信小程序 ──────────────────────────────────────────────────
# 微信小程序 AppID 和 AppSecret (用于小程序登录)
# WX_APP_ID=wx_your_app_id
# WX_APP_SECRET=your_app_secret

# ── 邮件服务（三选一，优先级 SendGrid > Resend > SMTP）────────────
# 选项 1：SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxx

# 选项 2：Resend
# RESEND_API_KEY=re_xxxxxxxxxx

# 选项 3：SMTP（如新浪邮箱）
# SMTP_HOST=smtp.sina.com
# SMTP_PORT=465
# SMTP_USER=yourmail@sina.com
# SMTP_PASS=yourpassword
# SMTP_FROM=yourmail@sina.com

# 注意：如果不配置任何邮件服务，
# 系统将在开发模式下直接在接口响应中返回验证码（dev_code）

# ── 阿里云短信（手机号验证码登录）──────────────────────────────
# 在阿里云控制台 → 短信服务 中获取以下配置
# ALIYUN_ACCESS_KEY_ID=your_access_key_id
# ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
# ALIYUN_SMS_SIGN_NAME=情感星球          # 短信签名（需在控制台审核通过）
# ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789  # 验证码模板代码（模板内容示例：验证码${code}，10分钟有效）
# 注意：未配置时进入开发模式，验证码会在接口响应中以 dev_code 字段返回

# ── 小红书小程序 ────────────────────────────────────────────────
# XHS_APP_ID=your_xhs_app_id
# XHS_APP_SECRET=your_xhs_app_secret

# ── CORS ─────────────────────────────────────────────────────────
# 生产环境设置具体域名（逗号分隔），开发环境用 *
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
